  Serial.println("├─────────────────────────────────────┤");
  Serial.printf( "│  Temp     : %-6.2f °C  %s         │\n", r.temperature, r.dht_valid   ? "✅" : "⚠️ ");
  Serial.printf( "│  Humidity : %-6.2f %%   %s         │\n", r.humidity,    r.dht_valid   ? "✅" : "⚠️ ");
  Serial.printf( "│  CO2      : %-8.2f ppm %s       │\n",   r.co2,         r.mq135_valid ? "✅" : "⚠️ ");
  Serial.printf( "│  CO       : %-8.4f ppm %s       │\n",   r.carbon_monoxide, r.mq135_valid ? "✅" : "⚠️ ");
  Serial.printf( "│  NOx      : %-8.4f ppm %s       │\n",   r.nitrogen_oxide,  r.mq135_valid ? "✅" : "⚠️ ");
  Serial.printf( "│  Dust     : %-6.2f µg/m³ %s      │\n",  r.dust,        r.dust_valid  ? "✅" : "⚠️ ");
  Serial.printf( "│  PM2.5    : %-6.2f µg/m³ %s      │\n",  r.pm25,        r.dust_valid  ? "✅" : "⚠️ ");
  Serial.printf( "│  PM10     : %-6.2f µg/m³ %s      │\n",  r.pm10,        r.dust_valid  ? "✅" : "⚠️ ");
  Serial.println("├─────────────────────────────────────┤");
  Serial.printf( "│  POST     : %-27s│\n", postSuccess ? "✅ SUCCESS" : "❌ FAILED");
  Serial.printf( "│  Sent OK  : %-5lu  │  Failed: %-5lu    │\n", totalSent, totalFailed);
  Serial.println("└─────────────────────────────────────┘");
}

// ─────────────────────────────────────────────────────────────
//  LCD DISPLAY
// ─────────────────────────────────────────────────────────────
void displayOnLCD(const SensorReading& r, bool postSuccess) {
  lcd.clear();

  // Row 0: Temperature & Humidity
  lcd.setCursor(0, 0);
  lcd.print("T:");
  lcd.print(r.temperature, 1);
  lcd.print((char)223);    // ° symbol
  lcd.print("C H:");
  lcd.print(r.humidity, 0);
  lcd.print("%");

  // Row 1: CO2 and POST status
  lcd.setCursor(0, 1);
  lcd.print("CO2:");
  lcd.print(r.co2, 0);
  lcd.print("  ");
  lcd.print(postSuccess ? "OK" : "ERR");
}

void lcdStatus(String line1, String line2) {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(line1.substring(0, 16));
  lcd.setCursor(0, 1);
  lcd.print(line2.substring(0, 16));
}
